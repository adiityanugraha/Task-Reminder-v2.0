<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Notifikasi pengingat deadline (Fitur-07, Personal Mode) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TaskReminder2">

        <activity
            android:name=".ui.tasklist.TaskListActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.taskdetail.TaskDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.tasklist.TaskListActivity" />

        <activity
            android:name=".ui.tasklist.TaskFormActivity"
            android:exported="false"
            android:parentActivityName=".ui.tasklist.TaskListActivity" />

        <activity
            android:name=".ui.team.LoginActivity"
            android:exported="false"
            android:parentActivityName=".ui.tasklist.TaskListActivity" />

        <activity
            android:name=".ui.team.RegisterActivity"
            android:exported="false"
            android:parentActivityName=".ui.team.LoginActivity" />

        <activity
            android:name=".ui.team.TeamHomeActivity"
            android:exported="false"
            android:parentActivityName=".ui.tasklist.TaskListActivity" />

        <activity
            android:name=".ui.team.TeamTasksActivity"
            android:exported="false"
            android:parentActivityName=".ui.team.TeamHomeActivity" />

        <activity
            android:name=".ui.team.TeamTaskFormActivity"
            android:exported="false"
            android:parentActivityName=".ui.team.TeamTasksActivity" />

        <activity
            android:name=".ui.team.TeamTaskDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.team.TeamTasksActivity" />

        <activity
            android:name=".ui.team.ManageTeamActivity"
            android:exported="false"
            android:parentActivityName=".ui.team.TeamTasksActivity" />

        <!-- Pengingat deadline berbunyi ke sini (Fitur-07, Day 25) -->
        <receiver
            android:name=".notification.AlarmReceiver"
            android:exported="false" />

        <!-- Jadwalkan ulang alarm setelah reboot (Fitur-07, Day 26) -->
        <receiver
            android:name=".notification.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
