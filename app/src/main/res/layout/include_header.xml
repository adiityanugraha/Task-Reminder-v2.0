<?xml version="1.0" encoding="utf-8"?>
<!-- Header layar (back + judul tengah), dipakai ulang sub-layar redesign.
     Activity memanggil BaseToolbarActivity.setupHeader(titleRes) untuk wiring. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp">

    <FrameLayout
        android:id="@+id/btnBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_icon_box"
        android:backgroundTint="@color/es_surface"
        android:clickable="true"
        android:elevation="2dp"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@string/action_cancel"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/es_text_primary" />
    </FrameLayout>

    <TextView
        android:id="@+id/textHeaderTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/es_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Slot aksi kanan (mis. menu pada Detail). Selalu 42x42 agar judul tetap
         di tengah; ikon disembunyikan & wiring diatur Activity bila perlu. -->
    <FrameLayout
        android:id="@+id/btnHeaderAction"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:clickable="false"
        android:focusable="false"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/imageHeaderAction"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_more"
            android:src="@drawable/ic_more"
            android:visibility="gone"
            app:tint="@color/es_text_primary" />
    </FrameLayout>

</LinearLayout>
